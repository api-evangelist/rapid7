{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PerformanceConfig",
  "title": "PerformanceConfig",
  "properties": {
    "max_concurrent_requests": {
      "type": "integer",
      "format": "int64"
    },
    "max_bandwidth_kb": {
      "type": "integer",
      "format": "int64"
    },
    "max_browser_reuse_count": {
      "type": "integer",
      "format": "int64"
    },
