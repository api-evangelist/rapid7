  "$id": "#/components/schemas/LuxorPageable",
  "title": "LuxorPageable",
  "properties": {
    "page_token": {
      "type": "string"
    },
    "offset": {
      "type": "integer",
      "format": "int64"
    },
    "sort": {
      "$ref": "#/components/schemas/Sort"
    },
    "page_size": {
      "type": "integer",
      "format": "int32"
    },
    "page_number": {
