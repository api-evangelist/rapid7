{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OauthConfig",
  "title": "OauthConfig",
  "properties": {
    "resource_owner_url": {
      "type": "string"
    },
    "resource_server_url": {
      "type": "string"
    },
    "authorization_server_url": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "client_scope": {
      "type": "string"
    },
    "client_state": {
      "type": "string"
    },
    "client_secret": {
      "type": "string"
    },
    "redirect_uri": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "username_form": {
      "type": "string"
    },
    "password_form": {
      "type": "string"
    },
    "extension_grant": {
      "type": "string"
    },
    "authorization_grant_type": {
      "type": "string",
      "enum": [
        "NULL",
        "AUTHORIZATION_CODE",
        "IMPLICIT",
        "RESOURCE_OWNER_PASSWORD_CREDENTIALS",
        "CLIENT_CREDENTIALS"
      ]
    },
    "never_do_basic_auth": {
      "type": "boolean"
    },
    "json_post_bodies": {
      "type": "boolean"
    },
    "token_server_url": {
      "type": "string"
    },
    "oauth_custom_field_list": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/OAuthCustomField"
      }
    }
  }
}