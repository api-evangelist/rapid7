{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OneTimePasswordConfig",
  "title": "OneTimePasswordConfig",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "NONE",
        "HOTP",
        "TOTP"
      ]
    },
    "algorithm": {
      "type": "string",
      "enum": [
        "SHA_1",
        "SHA_224",
        "SHA_256",
        "SHA_384",
        "SHA_512",
        "SHA_3_224",
        "SHA_3_256",
        "SHA_3_384",
        "SHA_3_512"
      ]
    },
    "counter": {
      "type": "integer",
      "format": "int64"
    },
    "period": {
      "type": "integer",
      "format": "int64"
    },
    "secret": {
      "type": "string"
    }
  }
}